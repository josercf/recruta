# RecrutaBot frontend — public configuration (Vite). Copy to `.env`.
# The anon key is PUBLIC by design and protected by Row Level Security.
# NEVER put the service_role key or the Anthropic key here.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Base URL of the .NET backend (no trailing slash), e.g. your Azure host.
VITE_API_BASE_URL=https://recrutabot-api.example.com
